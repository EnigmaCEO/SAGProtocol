# ── Hardhat / deployment ──────────────────────────────────────────────────────

# Deployer private key (hex, with or without 0x prefix).
# Used by Hardhat when running: npx hardhat run scripts/deploy.ts --network moonbase
MOONBASE_PRIVATE_KEY_0=0xYOUR_DEPLOYER_PRIVATE_KEY

# Override the default Moonbase Alpha RPC (optional)
MOONBASE_RPC_URL=https://rpc.api.moonbase.moonbeam.network

# Base URI for receipt NFT metadata endpoint.
# Set this to your Vercel deployment URL before deploying contracts.
# e.g. https://your-app.vercel.app/api/metadata/
NFT_METADATA_BASE_URI=http://localhost:3000/api/metadata/

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Copy to frontend/.env.local and set for local dev.
# On Vercel set these as Environment Variables in the project settings.

NEXT_PUBLIC_RPC_URL=https://rpc.api.moonbase.moonbeam.network
NEXT_PUBLIC_CHAIN_ID=1287

# ── Banking / Postgres ────────────────────────────────────────────────────────
# PostgreSQL connection string for banking persistence.
DATABASE_URL=postgresql://user:password@localhost:5432/sagitta_banking
# Set to 'true' if your Postgres provider requires SSL (e.g. Supabase, Neon, RDS).
DATABASE_SSL=false

# ── Circle (fiat onramp / USDC rail) ─────────────────────────────────────────
CIRCLE_API_KEY=TEST_API_KEY:your_key_here
# 'sandbox' for testing, 'production' for live.
CIRCLE_ENV=sandbox
# No webhook secret needed: Circle uses ECDSA verification with a per-event
# public key fetched from GET /v2/notifications/publicKey/{keyId}.
# The X-Circle-Key-Id and X-Circle-Signature headers are used automatically.
# Destination blockchain and wallet address for first-party USDC payouts.
# Set CIRCLE_BLOCKCHAIN to the chain identifier Circle uses (e.g. ETH, MATIC, ARB, ARC).
CIRCLE_BLOCKCHAIN=ETH
CIRCLE_DESTINATION_ADDRESS=0xYOUR_PROTOCOL_WALLET_ADDRESS
# Optional: cached Circle business wire bank account ID (avoids repeated lookups).
CIRCLE_SOURCE_BANK_ACCOUNT_ID=

# ── Banking / Treasury (on-chain) ─────────────────────────────────────────────
# Address of the deployed Treasury contract.
BANKING_TREASURY_ADDRESS=0xYOUR_TREASURY_CONTRACT_ADDRESS
# Operator private key used to sign Treasury transactions from the banking backend.
BANKING_TREASURY_PRIVATE_KEY=0xYOUR_OPERATOR_PRIVATE_KEY
# RPC endpoint for on-chain Treasury reads/writes (defaults to NEXT_PUBLIC_RPC_URL).
BANKING_RPC_URL=https://rpc.api.moonbase.moonbeam.network
