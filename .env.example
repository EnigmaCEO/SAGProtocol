# ── Hardhat / deployment ──────────────────────────────────────────────────────

# Deployer private key (hex, with or without 0x prefix).
# Used by Hardhat when running: npx hardhat run scripts/deploy.ts --network moonbase
MOONBASE_PRIVATE_KEY_0=0xYOUR_DEPLOYER_PRIVATE_KEY

# Override the default Moonbase Alpha RPC (optional)
MOONBASE_RPC_URL=https://rpc.api.moonbase.moonbeam.network

# Base URI for receipt NFT metadata endpoint.
# Set this to your Vercel deployment URL before deploying contracts.
# e.g. https://your-app.vercel.app/api/metadata/
NFT_METADATA_BASE_URI=http://localhost:3000/api/metadata/

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Copy to frontend/.env.local and set for local dev.
# On Vercel set these as Environment Variables in the project settings.

NEXT_PUBLIC_RPC_URL=https://rpc.api.moonbase.moonbeam.network
NEXT_PUBLIC_CHAIN_ID=1287
